<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/naturutas_background"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/naturutas_surface"
        app:cardCornerRadius="22dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/naturutas_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comparar rutas"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/naturutas_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Selecciona dos recorridos y la métrica que quieres analizar."
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/naturutas_secondary_text" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/naturutas_surface"
        app:cardCornerRadius="22dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/naturutas_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:text="Ruta 1"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="@color/naturutas_on_surface" />

            <Spinner
                android:id="@+id/route1Spinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_naturutas_input"
                android:minHeight="48dp"
                android:popupBackground="@color/naturutas_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:text="Ruta 2"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textColor="@color/naturutas_on_surface" />

            <Spinner
                android:id="@+id/route2Spinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_naturutas_input"
                android:minHeight="48dp"
                android:popupBackground="@color/naturutas_surface" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/metricsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="Métricas"
                    android:textAllCaps="false"
                    android:textColor="@color/naturutas_primary"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/naturutas_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/compareButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="Comparar rutas"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:backgroundTint="@color/naturutas_primary"
                    app:cornerRadius="24dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/naturutas_surface"
        app:cardCornerRadius="22dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/naturutas_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Resultados"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/naturutas_on_surface"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/graphicLayout"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:orientation="vertical" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
