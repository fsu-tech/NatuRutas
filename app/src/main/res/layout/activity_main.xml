<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Contenedor principal para los fragmentos -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation" />


    <!-- Botón Panel profesional solo visible en ajustes -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPanelProfesionalAjustes"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_above="@id/bottom_navigation"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:minWidth="0dp"
        android:text="Panel profesional"
        android:textAllCaps="false"
        android:textColor="@color/naturutas_on_primary"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="@color/naturutas_primary"
        app:cornerRadius="24dp" />

    <!-- Barra de navegación inferior -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_alignParentBottom="true"
        android:background="@color/naturutas_surface"
        android:elevation="12dp"
        app:itemActiveIndicatorStyle="@style/Widget.Material3.BottomNavigationView.ActiveIndicator"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>

