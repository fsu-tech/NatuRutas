<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- CABECERA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Panel Profesional"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NatuRutas analiza el comportamiento de usuarios en actividades outdoor y genera información útil para empresas del sector deportivo y turístico."
            android:textSize="14sp"
            android:textColor="#555555"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

        <!-- SECCIÓN 1: DATOS DISPONIBLES -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🟢  Datos disponibles"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- SECCIÓN 2: QUÉ OFRECEMOS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔥  Qué ofrecemos a empresas"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Dashboards personalizados de actividad\n• Análisis de mercado outdoor por zona\n• Segmentación de usuarios por perfil\n• Mapas de calor de rutas más usadas\n• Detección de puntos de abandono\n• Recomendaciones de negocio basadas en datos\n\n💬 NatuRutas puede transformarse en una plataforma de inteligencia de negocio para el sector deportivo y turístico."
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <!-- SECCIÓN 3: CONTACTO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🟣  ¿Te interesa? Contacta con nosotros"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#6A1B9A"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Quieres acceder a estos datos o a un dashboard personalizado? Escríbenos y te explicamos cómo puede ayudarte NatuRutas."
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSolicitarInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📧  Solicitar información por email"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnWhatsApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬  Contactar por WhatsApp"
            android:backgroundTint="#25D366"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</ScrollView>
